MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5d26ff330caa421d3ae3be24830f9654, type: 3}
  m_Name: TutorialData
  m_EditorClassIdentifier: Assembly-CSharp::TutorialData
  talkScript:
  - text: Em GolfDuel, dois jogadores se enfrentam em partidas de golfe 1v1.
    mediaType: 1
    image: {fileID: 21300000, guid: 4dc5da3e6a821c7b6a80e8435be8e73a, type: 3}
    animationTrigger: 
    animationFrames: []
    frameDelay: 0
  - text: O objetivo? Terminar todas as rodadas com a menor quantidade de tacadas
      para atingir a bandeira.
    mediaType: 2
    image: {fileID: 21300000, guid: 544dfbfd9edec558a8274a9f513a0f75, type: 3}
    animationTrigger: 
    animationFrames:
    - {fileID: 21300000, guid: 544dfbfd9edec558a8274a9f513a0f75, type: 3}
    - {fileID: 21300000, guid: 2584cc677c0dd941cb0c77ecc2a3d4c1, type: 3}
    - {fileID: 21300000, guid: f2f67d80a1d9632f083d63280b50fd7f, type: 3}
    frameDelay: 1
  - text: A cada rodada, cada jogador pode escolher entre diferentes buffs e barreiras
      para se ajudar ou atrapalhar seu oponente.
    mediaType: 2
    image: {fileID: 21300000, guid: 55f666697941c331ebd956d8f717434f, type: 3}
    animationTrigger: 
    animationFrames:
    - {fileID: 21300000, guid: 55f666697941c331ebd956d8f717434f, type: 3}
    - {fileID: 21300000, guid: b64bd81516a86e2aea97dc3012f45245, type: 3}
    - {fileID: 21300000, guid: 227873867cdb41ef2abac769b02ae58e, type: 3}
    - {fileID: 21300000, guid: 5b6248c376e55276a98c77415ee74290, type: 3}
    frameDelay: 1
  - text: Depois da fase de escolha, os jogadores tentam completar o circuito da
      maneira mais eficiente que conseguirem.
    mediaType: 2
    image: {fileID: 0}
    animationTrigger: 
    animationFrames:
    - {fileID: 7327084728262749817, guid: f6109cf7c79f24b85b1a01dcfb94fd3d, type: 3}
    - {fileID: 7350583992441606597, guid: 2d8ea24e2346f38798b7e603a0e55d91, type: 3}
    - {fileID: -755273717008193585, guid: a994a0aad16b7992596326a6d5014f9d, type: 3}
    - {fileID: -5275491173489149280, guid: 064da412a09a9f5beb3f05ec1546f57b, type: 3}
    - {fileID: 1537869381000566567, guid: e0f41c0c5ef1808b992c881f55d49bdb, type: 3}
    - {fileID: -8230425992573538005, guid: 3dcdac778f215cf83979ce83e76a84f4, type: 3}
    - {fileID: 1820243551359792020, guid: 007c54e62ea40b9c88e0eb597913fcf9, type: 3}
    - {fileID: 896911363081290487, guid: 9a892ffdfee3e5492aca5f1f20870571, type: 3}
    frameDelay: 1
  - text: Para fazer uma tacada, pressione o cursor na bola, direcione sua jogada
      da forma que quiser e ajuste a intensidade de seu movimento.
    mediaType: 2
    image: {fileID: 0}
    animationTrigger: 
    animationFrames:
    - {fileID: 21300000, guid: 372a2c44cb93a5204a044c6394139393, type: 3}
    - {fileID: 21300000, guid: 72dd9b8655e9dfbbea8282fab37fb6f5, type: 3}
    - {fileID: 21300000, guid: 4194d99f44f65ceaaad44404638b6904, type: 3}
    - {fileID: 21300000, guid: 9dc805358b67a66d28c5524b8f517814, type: 3}
    frameDelay: 1
